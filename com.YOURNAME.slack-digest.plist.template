<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!-- LaunchAgent: auto-regenerates data.js every hour on weekdays 7 AM–5 PM.
     See README.md for setup instructions. -->
<plist version="1.0">
<dict>

  <!-- Replace com.YOURNAME with e.g. com.jsmith -->
  <key>Label</key>
  <string>com.YOURNAME.slack-digest</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <!-- Replace with the absolute path to YOUR copy of this repo -->
    <string>YOUR_REPO_PATH/tools/slack-digest/regenerate.sh</string>
  </array>

  <!-- Run at login so it's fresh when you open your computer -->
  <key>RunAtLoad</key>
  <true/>

  <!-- Every hour Mon–Fri 7 AM – 5 PM -->
  <key>StartCalendarInterval</key>
  <array>
